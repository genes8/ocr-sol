{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ocr-saas.example.com/schemas/bank_statement_v1.json",
  "title": "Bank Statement Schema",
  "description": "JSON schema for bank statement document extraction",
  "version": "1.0",
  "type": "object",
  "required": ["account_holder", "account_number", "statement_period", "transactions"],
  "properties": {
    "bank_name": {
      "type": "string",
      "description": "Name of the bank"
    },
    "bank_code": {
      "type": "string",
      "description": "Bank identification code"
    },
    "account_holder": {
      "type": "string",
      "description": "Account holder name",
      "minLength": 1
    },
    "account_number": {
      "type": "string",
      "description": "Bank account number ( Serbian format: XXX-XXXXXXXXXXXXX-XX )"
    },
    "statement_number": {
      "type": "string",
      "description": "Statement number/identifier"
    },
    "statement_period": {
      "type": "object",
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "end_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "currency": {
      "type": "string",
      "default": "RSD",
      "enum": ["RSD", "EUR", "USD"]
    },
    "opening_balance": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "type": {
          "type": "string",
          "enum": ["debit", "credit"]
        }
      }
    },
    "closing_balance": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "type": {
          "type": "string",
          "enum": ["debit", "credit"]
        }
      }
    },
    "totals": {
      "type": "object",
      "properties": {
        "total_credits": {
          "type": "number",
          "description": "Sum of all credit transactions"
        },
        "total_debits": {
          "type": "number",
          "description": "Sum of all debit transactions"
        },
        "number_of_credits": {
          "type": "integer"
        },
        "number_of_debits": {
          "type": "integer"
        },
        "number_of_transactions": {
          "type": "integer"
        }
      }
    },
    "transactions": {
      "type": "array",
      "description": "List of all transactions",
      "items": {
        "type": "object",
        "required": ["date", "description", "amount", "type"],
        "properties": {
          "row_number": {
            "type": "integer",
            "minimum": 1
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Transaction date"
          },
          "value_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Value date"
          },
          "type": {
            "type": "string",
            "enum": ["credit", "debit", "deposit", "withdrawal", "transfer_in", "transfer_out", "fee", "interest", "payment", "refund"]
          },
          "description": {
            "type": "string",
            "description": "Transaction description",
            "minLength": 1
          },
          "counterparty": {
            "type": "object",
            "description": "Counterparty information",
            "properties": {
              "name": {
                "type": "string"
              },
              "account_number": {
                "type": "string"
              },
              "bank_name": {
                "type": "string"
              },
              "pib": {
                "type": "string",
                "pattern": "^\\d{9}$"
              }
            }
          },
          "amount": {
            "type": "number",
            "description": "Transaction amount"
          },
          "currency": {
            "type": "string",
            "default": "RSD"
          },
          "balance_after": {
            "type": "number",
            "description": "Balance after this transaction"
          },
          "balance_type": {
            "type": "string",
            "enum": ["debit", "credit"]
          },
          "reference_number": {
            "type": "string",
            "description": "Bank reference number"
          },
          "model": {
            "type": "string",
            "description": "Payment model code"
          },
          "invoice_reference": {
            "type": "string",
            "description": "Invoice/order reference"
          },
          "purpose_code": {
            "type": "string",
            "description": "Purpose code for the transaction"
          }
        }
      }
    },
    "fees": {
      "type": "array",
      "description": "Bank fees charged",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    },
    "interest": {
      "type": "object",
      "properties": {
        "credit_interest": {
          "type": "number",
          "description": "Interest earned"
        },
        "debit_interest": {
          "type": "number",
          "description": "Interest charged"
        },
        "interest_rate": {
          "type": "number",
          "description": "Interest rate percentage"
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ocr-saas.example.com/schemas/invoice_v1.json",
  "title": "Invoice Schema",
  "description": "JSON schema for invoice document extraction with Serbian format support",
  "version": "1.0",
  "type": "object",
  "required": ["invoice_number", "invoice_date", "supplier", "buyer", "line_items", "totals"],
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Invoice number/identifier",
      "minLength": 1,
      "examples": ["2024-00142", "FA-2024-001", "1/2024"]
    },
    "invoice_date": {
      "type": "string",
      "description": "Invoice issue date in ISO 8601 format (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "examples": ["2024-11-15"]
    },
    "due_date": {
      "type": "string",
      "description": "Payment due date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "examples": ["2024-12-15"]
    },
    "place_of_issue": {
      "type": "string",
      "description": "Place where invoice was issued",
      "examples": ["Beograd", "Novi Sad"]
    },
    "currency": {
      "type": "string",
      "default": "RSD",
      "description": "Currency code (RSD, EUR, USD)",
      "enum": ["RSD", "EUR", "USD"]
    },
    "supplier": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Supplier company name",
          "minLength": 1
        },
        "address": {
          "type": "string",
          "description": "Supplier street address"
        },
        "city": {
          "type": "string",
          "description": "City"
        },
        "postal_code": {
          "type": "string",
          "description": "Postal/ZIP code",
          "pattern": "^\\d{4,6}$"
        },
        "country": {
          "type": "string",
          "default": "Srbija",
          "description": "Country"
        },
        "pib": {
          "type": "string",
          "pattern": "^\\d{9}$",
          "description": "Serbian tax identification number (9 digits)"
        },
        "mb": {
          "type": "string",
          "description": "Company registration number"
        },
        "bank_name": {
          "type": "string",
          "description": "Bank name"
        },
        "bank_account": {
          "type": "string",
          "description": "Bank account number"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        }
      }
    },
    "buyer": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Buyer company name",
          "minLength": 1
        },
        "address": {
          "type": "string",
          "description": "Buyer street address"
        },
        "city": {
          "type": "string",
          "description": "City"
        },
        "postal_code": {
          "type": "string",
          "pattern": "^\\d{4,6}$"
        },
        "country": {
          "type": "string",
          "default": "Srbija",
          "description": "Country"
        },
        "pib": {
          "type": "string",
          "pattern": "^\\d{9}$",
          "description": "Buyer tax identification number"
        },
        "mb": {
          "type": "string",
          "description": "Company registration number"
        }
      }
    },
    "line_items": {
      "type": "array",
      "description": "Invoice line items (at least one required for valid invoice)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price", "line_total"],
        "properties": {
          "row_number": {
            "type": "integer",
            "description": "Row/line number on invoice",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "description": "Item or service description",
            "minLength": 1
          },
          "sku": {
            "type": "string",
            "description": "Product/SKU code"
          },
          "quantity": {
            "type": "number",
            "description": "Quantity ordered",
            "minimum": 0
          },
          "unit": {
            "type": "string",
            "description": "Unit of measure",
            "default": "kom",
            "examples": ["kom", "kg", "sat", "dan", "mesec"]
          },
          "unit_price": {
            "type": "number",
            "description": "Unit price without VAT",
            "minimum": 0
          },
          "vat_rate": {
            "type": "number",
            "description": "VAT rate percentage",
            "enum": [0, 10, 20],
            "default": 20
          },
          "vat_amount": {
            "type": "number",
            "description": "Calculated VAT amount for this line",
            "minimum": 0
          },
          "line_total": {
            "type": "number",
            "description": "Line total including VAT",
            "minimum": 0
          },
          "discount_percent": {
            "type": "number",
            "description": "Discount percentage (0-100)",
            "minimum": 0,
            "maximum": 100
          },
          "discount_amount": {
            "type": "number",
            "description": "Discount amount"
          },
          "net_amount": {
            "type": "number",
            "description": "Net amount before VAT"
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": ["subtotal", "vat_total", "grand_total"],
      "properties": {
        "subtotal": {
          "type": "number",
          "description": "Subtotal before VAT"
        },
        "total_discount": {
          "type": "number",
          "description": "Total discount amount"
        },
        "vat_breakdown": {
          "type": "array",
          "description": "VAT breakdown by rate",
          "items": {
            "type": "object",
            "required": ["vat_rate", "taxable_amount", "vat_amount"],
            "properties": {
              "vat_rate": {
                "type": "number",
                "enum": [0, 10, 20]
              },
              "taxable_amount": {
                "type": "number"
              },
              "vat_amount": {
                "type": "number"
              }
            }
          }
        },
        "vat_total": {
          "type": "number",
          "description": "Total VAT amount"
        },
        "grand_total": {
          "type": "number",
          "description": "Grand total including VAT",
          "minimum": 0
        },
        "amount_in_words": {
          "type": "string",
          "description": "Amount written in words (Serbian)"
        }
      }
    },
    "payment_info": {
      "type": "object",
      "properties": {
        "payment_method": {
          "type": "string",
          "enum": ["cash", "bank_transfer", "card", "check", "other"]
        },
        "bank_name": {
          "type": "string",
          "description": "Bank name for payment"
        },
        "bank_account": {
          "type": "string",
          "description": "Buyer bank account"
        },
        "reference": {
          "type": "string",
          "description": "Payment reference/model"
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or comments"
    },
    "signatures": {
      "type": "object",
      "properties": {
        "issued_by": {
          "type": "string",
          "description": "Name of person issuing invoice"
        },
        "approved_by": {
          "type": "string",
          "description": "Name of person approving"
        }
      }
    }
  }
}

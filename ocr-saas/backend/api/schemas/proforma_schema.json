{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ocr-saas.example.com/schemas/proforma_v1.json",
  "title": "Proforma Invoice Schema",
  "description": "JSON schema for proforma invoice document extraction",
  "version": "1.0",
  "type": "object",
  "required": ["proforma_number", "issue_date", "supplier", "buyer", "line_items", "totals"],
  "properties": {
    "proforma_number": {
      "type": "string",
      "description": "Proforma invoice number",
      "minLength": 1
    },
    "issue_date": {
      "type": "string",
      "description": "Issue date in ISO 8601 format",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "valid_until": {
      "type": "string",
      "description": "Validity expiration date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "place_of_issue": {
      "type": "string",
      "description": "Place where proforma was issued"
    },
    "currency": {
      "type": "string",
      "default": "RSD",
      "enum": ["RSD", "EUR", "USD"]
    },
    "supplier": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "address": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "postal_code": {
          "type": "string",
          "pattern": "^\\d{4,6}$"
        },
        "country": {
          "type": "string",
          "default": "Srbija"
        },
        "pib": {
          "type": "string",
          "pattern": "^\\d{9}$"
        },
        "mb": {
          "type": "string"
        },
        "bank_name": {
          "type": "string"
        },
        "bank_account": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "buyer": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "address": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "postal_code": {
          "type": "string"
        },
        "country": {
          "type": "string",
          "default": "Srbija"
        },
        "pib": {
          "type": "string",
          "pattern": "^\\d{9}$"
        },
        "mb": {
          "type": "string"
        }
      }
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price"],
        "properties": {
          "row_number": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "sku": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 0
          },
          "unit": {
            "type": "string",
            "default": "kom"
          },
          "unit_price": {
            "type": "number",
            "minimum": 0
          },
          "vat_rate": {
            "type": "number",
            "enum": [0, 10, 20],
            "default": 20
          },
          "line_total": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": ["subtotal", "grand_total"],
      "properties": {
        "subtotal": {
          "type": "number"
        },
        "total_discount": {
          "type": "number"
        },
        "vat_amount": {
          "type": "number",
          "description": "Note: proforma may or may not include VAT"
        },
        "grand_total": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "default": "RSD"
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    },
    "validity_days": {
      "type": "integer",
      "description": "Number of days the proforma is valid"
    }
  }
}
